{
  "apps": [{
    "name": "zagros",
    "script": "./server.js",
    "instances": 1,
    "exec_mode": "fork",
    "env": {
      "NODE_ENV": "production",
      "PORT": 5000
    },
    "max_memory_restart": "1G",
    "restart_delay": 3000,
    "min_uptime": "10s",
    "max_restarts": 5,
    "autorestart": true,
    "watch": false,
    "ignore_watch": ["node_modules", "client", "uploads", "data"],
    "log_file": "./logs/combined.log",
    "out_file": "./logs/out.log",
    "err_file": "./logs/err.log",
    "time": true
  }]
}
